PORT=8000
OUTPUT_DIR=outputs

# Optional: enable VLM layout review.
DASHSCOPE_API_KEY=
QWEN_VL_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Optional: experiment telemetry (JSONL per run). Default ON when using
# ``python -m app.main``; set to 0 for production runs without logging.
POSTER_EXPERIMENT_MODE=1
# POSTER_EXPERIMENT_LOG=outputs/runs/<run_folder>/experiment_log.jsonl

# --- Dify (only used by experiments/scripts/batch_dify_runs.py) -------------
# Dify CHATFLOW app API key. Get from Dify > your chatflow > "Access API"
# (starts with "app-..."). Leave empty if you don't need the batch Dify runner.
DIFY_API_KEY=
# Dify API base. http://localhost/v1 for self-hosted (default below);
# https://api.dify.ai/v1 for Dify Cloud.
DIFY_BASE_URL=http://localhost/v1
# The variable name in your chatflow's Start node that accepts the PDF file.
# Open your chatflow in Dify > Start node > Input Variables — copy the exact name.
DIFY_WORKFLOW_INPUT_NAME=paper
# Any string Dify will tag this batch's runs with (helps you filter in Dify UI).
DIFY_USER_ID=experiment-batch
# Required `query` field for chatflow apps; content doesn't really matter
# because the real input is the PDF passed via DIFY_WORKFLOW_INPUT_NAME.
DIFY_QUERY=Generate a conference-style poster from this paper.
