PORT=8000
OUTPUT_DIR=outputs

# Optional: enable VLM layout review.
DASHSCOPE_API_KEY=
QWEN_VL_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Optional: experiment telemetry (JSONL per run). Default ON when using
# ``python -m app.main``; set to 0 for production runs without logging.
POSTER_EXPERIMENT_MODE=1
# POSTER_EXPERIMENT_LOG=outputs/runs/<run_folder>/experiment_log.jsonl
